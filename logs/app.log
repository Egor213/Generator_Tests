import pytest
from typing import List, Dict, Any
from main import seven_level_maze


class TestSevenLevelMazeUncovered:
    """Тесты для покрытия непокрытых ветвей функции seven_level_maze."""

    @pytest.mark.asyncio
    async def test_seven_level_maze_depth_exceeds_max_continue(self) -> None:
        """Проверяет ветку 'continue' при depth > max_depth."""
        data = [{"a": {"b": {"c": "deep_value"}}}]
        keys = ["a", "b", "c"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=0)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_dict_items_iteration(self) -> None:
        """Проверяет итерацию по obj.items() для словаря."""
        data = [{"x": 1, "y": 2, "z": 3}]
        keys = ["x"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_key_pos_within_keys_and_key_match(self) -> None:
        """Проверяет совпадение ключа при key_pos < len(keys) и k == keys[key_pos]."""
        data = [{"a": 42}]
        keys = ["a", "b"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_depth_at_least_min_depth(self) -> None:
        """Проверяет ветку при depth >= min_depth с подходящим значением."""
        data = [{"a": {"b": "value"}}]
        keys = ["a", "b"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_value_is_dict_or_list(self) -> None:
        """Проверяет ветку isinstance(v, (dict, list)) при dict значении."""
        data = [{"a": {"b": {"c": "found"}}}]
        keys = ["a", "b", "c"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == [{"c": "found"}]

    @pytest.mark.asyncio
    async def test_seven_level_maze_key_pos_plus_one_equals_len_keys(self) -> None:
        """Проверяет добавление в results при key_pos + 1 == len(keys)."""
        data = [{"a": {"b": "final"}}]
        keys = ["a", "b"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == ["final"]

    @pytest.mark.asyncio
    async def test_seven_level_maze_stack_append_for_further_traversal(self) -> None:
        """Проверяет добавление в stack при key_pos + 1 < len(keys)."""
        data = [{"a": {"b": {"c": "deep"}}}]
        keys = ["a", "b", "c"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == ["deep"]

    @pytest.mark.asyncio
    async def test_seven_level_maze_list_value_at_final_key(self) -> None:
        """Проверяет добавление списка в results при совпадении всех ключей."""
        data = [{"a": {"b": [1, 2, 3]}}]
        keys = ["a", "b"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == [[1, 2, 3]]

    @pytest.mark.asyncio
    async def test_seven_level_maze_mixed_dict_and_list_traversal(self) -> None:
        """Проверяет обход при наличии списков на промежуточных уровнях."""
        data = [{"a": [{"b": {"c": "target"}}]}]
        keys = ["a", "b", "c"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_multiple_dicts_in_data(self) -> None:
        """Проверяет обработку нескольких словарей в data."""
        data = [
            {"a": {"b": "first"}},
            {"a": {"b": "second"}},
            {"x": "ignore"},
        ]
        keys = ["a", "b"]
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == ["first", "second"]
