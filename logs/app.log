import pytest
from typing import List, Dict, Any
from unittest.mock import patch
from main import seven_level_balanced_processor


class TestSevenLevelBalancedProcessor:
    """Тесты для функции seven_level_balanced_processor."""

    @pytest.mark.parametrize(
        "queue, priority_map, max_depth, expected",
        [
            (
                [{"name": "task1", "items": [{"active": True}, {"active": False}]}],
                {"items": 7},
                3,
                [
                    {
                        "name": "task1",
                        "items": [{"active": True}, {"active": False}],
                        "subtasks": [{"active": True, "priority": 7}],
                        "inactive": [{"active": False, "priority": 0}],
                    }
                ],
            ),
            (
                [{"field": [1, 2, 3]}],
                {"field": 6},
                3,
                [
                    {
                        "field": [1, 2, 3],
                        "non_dict_items": [1, 2, 3],
                    }
                ],
            ),
            (
                [{"data": "value"}],
                {"data": 4},
                3,
                [
                    {
                        "data": "value",
                        "non_list_fields": ["data"],
                    }
                ],
            ),
            (
                [{"unknown": [{"active": True}]}],
                {"other": 8},
                3,
                [
                    {
                        "unknown": [{"active": True}],
                        "unmapped_fields": ["unknown"],
                    }
                ],
            ),
            (
                [{"field": [{"active": True}, "text", 42]}],
                {"field": 5},
                3,
                [
                    {
                        "field": [{"active": True}, "text", 42],
                        "subtasks": [{"active": True, "priority": 5}],
                        "non_dict_items": ["text", 42],
                    }
                ],
            ),
            (
                [{"a": [{"active": True}], "b": [1]}],
                {"a": 5, "b": 3},
                3,
                [
                    {
                        "a": [{"active": True}],
                        "b": [1],
                        "subtasks": [{"active": True, "priority": 5}],
                        "low_priority_fields": ["b"],
                        "non_dict_items": [1],
                    }
                ],
            ),
            (
                [],
                {"x": 10},
                3,
                [],
            ),
            (
                [{"x": [{"active": True}]}, {"y": [{"active": False}]}],
                {"x": 6, "y": 7},
                3,
                [
                    {
                        "x": [{"active": True}],
                        "subtasks": [{"active": True, "priority": 6}],
                    },
                    {
                        "y": [{"active": False}],
                        "inactive": [{"active": False, "priority": 0}],
                    },
                ],
            ),
            (
                [{"field": [{"active": True}]}],
                {"field": 5},
                1,
                [
                    {
                        "field": [{"active": True}],
                        "subtasks": [{"active": True, "priority": 5}],
                    }
                ],
            ),
        ],
    )
    @pytest.mark.asyncio
    async def test_seven_level_balanced_processor_various_scenarios(
        self,
        queue: List[Dict[str, Any]],
        priority_map: Dict[str, int],
        max_depth: int,
        expected: List[Dict[str, Any]],
    ) -> None:
        """Проверяет корректность обработки различных комбинаций входных данных."""
        result = seven_level_balanced_processor(queue, priority_map, max_depth)
        assert result == expected

    @pytest.mark.asyncio
    async def test_seven_level_balanced_processor_preserves_original_queue(self) -> None:
        """Проверяет, что исходная очередь не изменяется (функция работает с копиями)."""
        original_queue = [{"name": "task", "items": [{"active": True}]}]
        queue_copy = [{"name": "task", "items": [{"active": True}]}]
        priority_map = {"items": 6}

        result = seven_level_balanced_processor(original_queue, priority_map)

        assert original_queue == queue_copy
        assert result != original_queue

    @pytest.mark.asyncio
    async def test_seven_level_balanced_processor_deepcopy_behavior(self) -> None:
        """Проверяет, что изменения в результате не влияют на исходные объекты."""
        inner_dict = {"active": True}
        queue = [{"items": [inner_dict]}]
        priority_map = {"items": 7}

        result = seven_level_balanced_processor(queue, priority_map)

        assert result[0]["subtasks"][0] is not inner_dict
        assert "priority" in result[0]["subtasks"][0]
        assert "priority" not in inner_dict

    @pytest.mark.asyncio
    async def test_seven_level_balanced_processor_attribute_error_handling(self) -> None:
        """Проверяет обработку исключений при доступе к атрибутам."""
        class BadItem:
            def get(self, key, default=None):
                raise AttributeError("broken")

        queue = [{"items": [BadItem()]}]
        priority_map = {"items": 5}

        result = seven_level_balanced_processor(queue, priority_map)

        assert result[0]["non_dict_items"][0] is BadItem()
