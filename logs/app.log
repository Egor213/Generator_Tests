import pytest
from typing import List, Dict
from unittest.mock import patch
from main import nine_level_priority_processor


class TestNineLevelPriorityProcessor:

    @pytest.fixture
    def sample_queue(self) -> List[Dict]:
        return [
            {
                "name": "task1",
                "tags": [
                    {"active": True, "id": 1},
                    {"active": False, "id": 2},
                    {"id": 3},
                ],
                "meta": {"version": 1},
            },
            {
                "name": "task2",
                "tags": [
                    {"active": True, "id": 4},
                ],
            },
        ]

    @pytest.fixture
    def priority_map(self) -> Dict[str, int]:
        return {"tags": 7, "meta": 3}

    @pytest.mark.asyncio
    @pytest.mark.parametrize(
        "queue,priority_map,max_depth,expected_length",
        [
            ([{"tags": [{"active": True}]}], {"tags": 5}, 3, 1),
            ([{"tags": [{"active": False}]}], {"tags": 5}, 3, 1),
            ([{"tags": [{"active": True}, {"active": True}]}], {"tags": 6}, 3, 1),
            ([{"other": [{"active": True}]}], {"tags": 5}, 3, 1),
            ([{"tags": "not_list"}], {"tags": 5}, 3, 1),
            ([{"tags": [{"active": True}]}, {"tags": [{"active": True}]}], {"tags": 8}, 3, 2),
        ],
    )
    async def test_processed_queue_length(
        self,
        queue: List[Dict],
        priority_map: Dict[str, int],
        max_depth: int,
        expected_length: int,
    ) -> None:
        """Проверяет длину возвращаемого списка после обработки очереди."""
        result = nine_level_priority_processor(queue, priority_map, max_depth)
        assert len(result) == expected_length

    @pytest.mark.asyncio
    @pytest.mark.parametrize(
        "queue,priority_map,expected_subtasks_count",
        [
            ([{"tags": [{"active": True}]}], {"tags": 5}, 1),
            ([{"tags": [{"active": False}]}], {"tags": 5}, 0),
            ([{"tags": [{"active": True}, {"active": True}]}], {"tags": 6}, 2),
            ([{"tags": [{"active": True}, {"active": False}]}], {"tags": 7}, 1),
            ([{"tags": [{"active": True}]}, {"tags": [{"active": True}]}], {"tags": 8}, 2),
        ],
    )
    async def test_subtasks_extraction_with_active_flag(
        self,
        queue: List[Dict],
        priority_map: Dict[str, int],
        expected_subtasks_count: int,
    ) -> None:
        """Проверяет извлечение подзадач с active=True и добавление поля priority."""
        result = nine_level_priority_processor(queue, priority_map)
        total_subtasks = sum(len(item.get("subtasks", [])) for item in result)
        assert total_subtasks == expected_subtasks_count
        for item in result:
            for subtask in item.get("subtasks", []):
                assert subtask.get("priority") == priority_map["tags"]

    @pytest.mark.asyncio
    async def test_priority_threshold_respected(self, sample_queue: List[Dict], priority_map: Dict[str, int]) -> None:
        """Проверяет, что приоритет >= 5 требуется для обработки списков."""
        low_priority_map = {"tags": 4}
        result = nine_level_priority_processor(sample_queue, low_priority_map)
        for item in result:
            assert "subtasks" not in item

    @pytest.mark.asyncio
    async def test_non_list_field_skipped(self, priority_map: Dict[str, int]) -> None:
        """Проверяет пропуск не-списковых значений для полей из priority_map."""
        queue = [{"tags": "not_a_list"}]
        result = nine_level_priority_processor(queue, priority_map)
        assert result[0]["tags"] == "not_a_list"
        assert "subtasks" not in result[0]

    @pytest.mark.asyncio
    async def test_non_dict_subitem_ignored(self, priority_map: Dict[str, int]) -> None:
        """Проверяет игнорирование элементов списка, не являющихся dict."""
        queue = [{"tags": [1, "two", None]}]
        result = nine_level_priority_processor(queue, priority_map)
        assert "subtasks" not in result[0]

    @pytest.mark.asyncio
    async def test_deepcopy_preserves_original_structure(self, sample_queue: List[Dict], priority_map: Dict[str, int]) -> None:
        """Проверяет, что исходные объекты в очереди не изменяются."""
        import copy
        original_copy = copy.deepcopy(sample_queue)
        nine_level_priority_processor(sample_queue, priority_map)
        assert sample_queue == original_copy

    @pytest.mark.asyncio
    async def test_field_not_in_priority_map_ignored(self, sample_queue: List[Dict]) -> None:
        """Проверяет, что поля, отсутствующие в priority_map, не обрабатываются."""
        result = nine_level_priority_processor(sample_queue, {})
        for item in result:
            assert "subtasks" not in item

    @pytest.mark.asyncio
    async def test_max_depth_unused_but_accepted(self, sample_queue: List[Dict], priority_map: Dict[str, int]) -> None:
        """Проверяет, что параметр max_depth не влияет на текущую логику, но принимается."""
        result_default = nine_level_priority_processor(sample_queue, priority_map)
        result_custom = nine_level_priority_processor(sample_queue, priority_map, max_depth=10)
        assert result_default == result_custom

    @pytest.mark.asyncio
    async def test_empty_queue_returns_empty_list(self, priority_map: Dict[str, int]) -> None:
        """Проверяет возврат пустого списка при пустой очереди."""
        result = nine_level_priority_processor([], priority_map)
        assert result == []

    @pytest.mark.asyncio
    async def test_attribute_error_in_subitem_handled_gracefully(self, priority_map: Dict[str, int]) -> None:
        """Проверяет корректную обработку исключения AttributeError внутри цикла."""

        class BadItem:
            def get(self, key, default=None):
                raise AttributeError("broken")

        queue = [{"tags": [BadItem()]}]
        result = nine_level_priority_processor(queue, priority_map)
        assert "subtasks" not in result[0]
