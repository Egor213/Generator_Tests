import pytest
from unittest.mock import MagicMock, patch
from service.task import TaskService
from entity.entity import Task


class TestTaskServiceCreateTask:
    """Тесты для метода TaskService.create_task"""

    @pytest.fixture
    def task_service(self):
        """Создает экземпляр TaskService для тестов."""
        return TaskService()

    @pytest.mark.parametrize(
        "description, priority",
        [
            ("Test task", 1),
            ("Another task", 3),
            ("Important task", 5),
            ("A" * 100, 2),
        ],
    )
    def test_create_task_valid_inputs_returns_correct_message(
        self, task_service, description, priority
    ):
        """Проверяет, что метод возвращает правильное сообщение при валидных входных данных."""
        result = task_service.create_task(description, priority)
        assert result == f"Task '{description}' created with priority {priority}"

    @pytest.mark.parametrize(
        "invalid_description",
        [
            "",
            "   ",
        ],
    )
    def test_create_task_empty_description_raises_value_error(
        self, task_service, invalid_description
    ):
        """Проверяет, что метод выбрасывает ValueError при пустом описании."""
        with pytest.raises(ValueError, match="Description cannot be empty"):
            task_service.create_task(invalid_description, 3)

    @pytest.mark.parametrize(
        "invalid_priority",
        [
            0,
            -1,
            6,
            10,
        ],
    )
    def test_create_task_invalid_priority_raises_value_error(
        self, task_service, invalid_priority
    ):
        """Проверяет, что метод выбрасывает ValueError при некорректном приоритете."""
        with pytest.raises(ValueError, match="Priority must be between 1 and 5"):
            task_service.create_task("Valid task", invalid_priority)

    def test_create_task_calls_manager_add_task_with_correct_arguments(
        self, task_service
    ):
        """Проверяет, что метод вызывает add_task у TaskManager с правильными аргументами."""
        description = "Test task"
        priority = 3
        with patch.object(task_service.manager, "add_task") as mock_add_task:
            task_service.create_task(description, priority)
            mock_add_task.assert_called_once_with(description, priority)

    def test_create_task_creates_and_modifies_internal_task_object(self, task_service):
        """Проверяет, что метод создает внутренний объект Task и вызывает его методы."""
        description = "Test task"
        priority = 3
        with patch("service.task.Task") as MockTask:
            mock_task_instance = MagicMock()
            MockTask.return_value = mock_task_instance
            task_service.create_task(description, priority)
            MockTask.assert_called_once_with("descr", 1)
            mock_task_instance.mark_completed.assert_called_once()
            mock_task_instance.test_method.assert_called_once()

    def test_create_task_with_explicit_none_task_argument_raises_type_error(
        self, task_service
    ):
        """Проверяет, что передача task=None приводит к TypeError из-за отсутствующего аргумента test."""
        description = "Test task"
        priority = 3
        with pytest.raises(TypeError, match="missing 1 required positional argument: 'test'"):
            task_service.create_task(description, priority, task=None)

    def test_create_task_with_faulty_task_object_raises_type_error(
        self, task_service
    ):
        """Проверяет, что передача объекта task с некорректным mark_completed приводит к TypeError."""
        class FaultyTask:
            def mark_completed(self):
                raise RuntimeError("Mark completed failed")

        description = "Test task"
        priority = 3
        mock_task = FaultyTask()
        with pytest.raises(TypeError, match="missing 1 required positional argument: 'test'"):
            task_service.create_task(description, priority, task=mock_task)

    def test_create_task_with_minimal_task_object_raises_type_error(
        self, task_service
    ):
        """Проверяет, что передача объекта task без необходимых методов приводит к TypeError."""
        class MinimalTask:
            pass

        description = "Test task"
        priority = 3
        mock_task = MinimalTask()
        with pytest.raises(TypeError, match="missing 1 required positional argument: 'test'"):
            task_service.create_task(description, priority, task=mock_task)
