import pytest
from typing import List, Dict
from unittest.mock import patch
from main import nine_level_priority_processor


class TestNineLevelPriorityProcessor:
    @pytest.fixture
    def sample_queue(self) -> List[Dict]:
        """Фикстура с базовой очередью задач для тестов."""
        return [
            {"id": 1, "name": "task1", "tags": [{"id": "a", "active": True}, {"id": "b", "active": False}]},
            {"id": 2, "name": "task2", "items": [{"id": "c", "active": True}]},
        ]

    @pytest.fixture
    def priority_map(self) -> Dict[str, int]:
        """Фикстура с маппингом приоритетов."""
        return {"tags": 7, "items": 5, "name": 3}

    @pytest.mark.parametrize(
        "queue, priority_map, max_depth, expected_len",
        [
            ([{"tags": [{"active": True}]}], {"tags": 7}, 3, 1),
            ([{"tags": [{"active": False}]}], {"tags": 7}, 3, 1),
            ([{"tags": [{"active": True}, {"active": True}]}], {"tags": 7}, 3, 1),
            ([{"other": [{"active": True}]}], {"tags": 7}, 3, 1),
            ([{"tags": "not_list"}], {"tags": 7}, 3, 1),
            ([{"tags": [{"no_active_key": True}]}], {"tags": 7}, 3, 1),
        ],
    )
    def test_priority_assignment_and_subtasks_creation(
        self,
        queue: List[Dict],
        priority_map: Dict[str, int],
        max_depth: int,
        expected_len: int,
    ) -> None:
        """
        Проверяет, что приоритет назначается только активным подэлементам-словарям
        и формируется список subtasks в обработанной задаче.
        """
        result = nine_level_priority_processor(queue, priority_map, max_depth)
        assert len(result) == expected_len
        processed_task = result[0]
        if "tags" in priority_map and priority_map["tags"] >= 5 and isinstance(queue[0].get("tags"), list):
            active_subs = [
                sub for sub in queue[0]["tags"]
                if isinstance(sub, dict) and sub.get("active", False)
            ]
            assert processed_task.get("subtasks", []) == active_subs
            for sub in processed_task.get("subtasks", []):
                assert sub.get("priority") == priority_map["tags"]

    @pytest.mark.parametrize(
        "priority_value, field_name, field_value, expect_priority_set",
        [
            (7, "tags", [{"active": True}], True),
            (4, "tags", [{"active": True}], False),
            (5, "items", [{"active": True}], True),
            (5, "items", [{"active": False}], False),
            (10, "deps", [{"active": True}, {"active": True}], True),
        ],
    )
    def test_priority_threshold_and_active_filter(
        self,
        priority_value: int,
        field_name: str,
        field_value: List[Dict],
        expect_priority_set: bool,
    ) -> None:
        """
        Проверяет порог приоритета (>=5) и фильтрацию только по active=True.
        """
        queue = [{field_name: field_value, "id": 1}]
        priority_map = {field_name: priority_value}
        result = nine_level_priority_processor(queue, priority_map, 3)
        assert len(result) == 1
        processed = result[0]
        if expect_priority_set:
            assert "subtasks" in processed
            for sub in processed["subtasks"]:
                assert sub.get("priority") == priority_value
        else:
            # либо нет subtasks, либо пустой список
            assert not processed.get("subtasks")

    def test_max_depth_unused_but_accepted(self) -> None:
        """
        Проверяет, что параметр max_depth принимается, но не влияет на текущую логику.
        """
        queue = [{"tags": [{"active": True}]}]
        priority_map = {"tags": 7}
        result_default = nine_level_priority_processor(queue, priority_map)
        result_custom = nine_level_priority_processor(queue, priority_map, max_depth=10)
        assert result_default == result_custom

    def test_non_dict_subitems_ignored(self) -> None:
        """
        Проверяет, что неподходящие подэлементы (не dict) не вызывают исключений
        и не добавляются в subtasks.
        """
        queue = [{"tags": ["string_item", 42, None, {"active": True}]}]
        priority_map = {"tags": 7}
        result = nine_level_priority_processor(queue, priority_map, 3)
        assert len(result) == 1
        processed = result[0]
        assert processed.get("subtasks") == [{"active": True, "priority": 7}]

    def test_attribute_error_on_subitem_handled_gracefully(self) -> None:
        """
        Проверяет, что AttributeError внутри блока try/except не ломает обработку.
        """

        class BadItem:
            def get(self, key, default=None):
                raise AttributeError("broken")

        queue = [{"tags": [BadItem()]}]
        priority_map = {"tags": 7}
        # Не должно выбросить исключение
        result = nine_level_priority_processor(queue, priority_map, 3)
        assert len(result) == 1
        assert "subtasks" not in result[0] or result[0]["subtasks"] == []

    def test_original_queue_consumed(self) -> None:
        """
        Проверяет, что входная очередь опустошается в процессе работы (pop(0) в цикле).
        """
        queue = [{"id": 1}, {"id": 2}]
        priority_map = {}
        nine_level_priority_processor(queue, priority_map, 3)
        assert queue == []

    def test_deepcopy_preserves_original_task_structure(self) -> None:
        """
        Проверяет, что исходные задачи не модифицируются напрямую (используется deepcopy).
        """
        original_task = {"tags": [{"active": True}]}
        queue = [original_task]
        priority_map = {"tags": 7}
        result = nine_level_priority_processor(queue, priority_map, 3)
        # В оригинальной задаче не должно появиться "priority" или "subtasks"
        assert "priority" not in original_task
        assert "subtasks" not in original_task
        # Но в результате должно быть
        assert result[0].get("subtasks", [{}])[0].get("priority") == 7

    def test_empty_queue_returns_empty_list(self) -> None:
        """
        Проверяет корректную обработку пустой очереди.
        """
        result = nine_level_priority_processor([], {"any": 5}, 3)
        assert result == []

    def test_field_not_in_priority_map_skipped(self) -> None:
        """
        Проверяет, что поля, отсутствующие в priority_map, не обрабатываются.
        """
        queue = [{"unknown": [{"active": True}]}]
        priority_map = {"known": 7}
        result = nine_level_priority_processor(queue, priority_map, 3)
        assert result == [{"unknown": [{"active": True}]}]
        assert "subtasks" not in result[0]
