import pytest
from typing import List, Dict, Any
from unittest.mock import patch
from main import nine_level_enhanced_processor


class TestNineLevelEnhancedProcessor:
    """Тесты для функции nine_level_enhanced_processor."""

    @pytest.fixture
    def sample_queue(self) -> List[Dict[str, Any]]:
        """Фикстура: базовая очередь задач для тестов."""
        return [
            {
                "task_id": 1,
                "data": [
                    {"active": True, "name": "sub1"},
                    {"active": False, "name": "sub2"},
                    "plain_value",
                ],
                "meta": {"info": "test"},
            },
            {
                "task_id": 2,
                "data": {"active": True},
                "extra": "value",
            },
        ]

    @pytest.fixture
    def priority_map(self) -> Dict[str, int]:
        """Фикстура: словарь приоритетов полей."""
        return {
            "data": 7,
            "task_id": 3,
        }

    @pytest.mark.asyncio
    @pytest.mark.parametrize(
        "queue,priority_map,default_priority,max_depth,expected_keys",
        [
            (
                [{"data": [{"active": True}]}],
                {"data": 5},
                1,
                3,
                {"processed_tasks", "low_priority_adjustments", "unmapped_fields",
                 "non_list_converted", "non_dict_wrapped", "error_handled"},
            ),
            (
                [{"unknown": "value"}],
                {},
                2,
                3,
                {"processed_tasks", "low_priority_adjustments", "unmapped_fields",
                 "non_list_converted", "non_dict_wrapped", "error_handled"},
            ),
        ],
    )
    async def test_return_structure(
        self,
        queue: List[Dict[str, Any]],
        priority_map: Dict[str, int],
        default_priority: int,
        max_depth: int,
        expected_keys: set,
    ) -> None:
        """Проверяет, что функция возвращает словарь с ожидаемыми ключами."""
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=default_priority,
            max_depth=max_depth,
        )
        assert isinstance(result, dict)
        assert set(result.keys()) == expected_keys

    @pytest.mark.asyncio
    async def test_processed_tasks_count(
        self,
        sample_queue: List[Dict[str, Any]],
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет количество обработанных задач."""
        result = nine_level_enhanced_processor(
            queue=sample_queue.copy(),
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        assert len(result["processed_tasks"]) == 2

    @pytest.mark.asyncio
    async def test_active_subtask_priority_assignment(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет назначение приоритета активным подзадачам."""
        queue = [
            {
                "data": [
                    {"active": True, "name": "sub1"},
                ],
            },
        ]
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        processed = result["processed_tasks"][0]
        assert "subtasks" in processed
        assert len(processed["subtasks"]) == 1
        assert processed["subtasks"][0]["priority"] == 7

    @pytest.mark.asyncio
    async def test_inactive_subtask_priority_and_reason(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет приоритет и причину для неактивных подзадач."""
        queue = [
            {
                "data": [
                    {"active": False, "name": "sub2"},
                ],
            },
        ]
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        processed = result["processed_tasks"][0]
        assert "inactive_subtasks" in processed
        assert len(processed["inactive_subtasks"]) == 1
        subtask = processed["inactive_subtasks"][0]
        assert subtask["priority"] == 5  # 7 - 2
        assert subtask["reason"] == "inactive"

    @pytest.mark.asyncio
    async def test_non_dict_wrapped_items(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет оборачивание не-словарей в списке."""
        queue = [
            {
                "data": ["plain_value"],
            },
        ]
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        assert len(result["non_dict_wrapped"]) == 1
        wrapped = result["non_dict_wrapped"][0]
        assert wrapped["value"] == "plain_value"
        assert wrapped["priority"] == 7
        assert wrapped["type"] == "wrapped"

    @pytest.mark.asyncio
    async def test_non_list_field_conversion(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет преобразование не-списка в список."""
        queue = [
            {
                "data": {"active": True},
            },
        ]
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        assert len(result["non_list_converted"]) == 1
        converted = result["non_list_converted"][0]
        assert "data" in converted
        assert isinstance(converted["data"], list)
        assert converted["data"][0] == {"active": True}

    @pytest.mark.asyncio
    async def test_low_priority_adjustment(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет корректировку низкого приоритета."""
        queue = [
            {
                "task_id": 99,
            },
        ]
        # priority_map["task_id"] = 3 (< 5) => low priority branch
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        assert len(result["low_priority_adjustments"]) == 1
        adjustment = result["low_priority_adjustments"][0]
        assert "task_id" in adjustment
        # p = 3 >= 1, so adjusted = p
        assert adjustment["task_id"] == 3

    @pytest.mark.asyncio
    async def test_unmapped_field_normalization(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет нормализацию полей, отсутствующих в priority_map."""
        queue = [
            {
                "extra": "value",
            },
        ]
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        assert len(result["unmapped_fields"]) == 1
        unmapped = result["unmapped_fields"][0]
        assert "extra" in unmapped
        norm = unmapped["extra"]
        assert norm["original"] == "value"
        assert norm["assigned_priority"] == 1
        assert norm["defaulted"] is True

    @pytest.mark.asyncio
    async def test_error_handling_in_subitems(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет обработку ошибок при доступе к подзадачам."""
        # None вместо dict вызовет TypeError при .get("active")
        queue = [
            {
                "data": [None],
            },
        ]
        result = nine_level_enhanced_processor(
            queue=queue,
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        assert len(result["error_handled"]) == 1
        error_item = result["error_handled"][0]
        assert "error" in error_item

    @pytest.mark.asyncio
    async def test_empty_queue(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Проверяет обработку пустой очереди."""
        result = nine_level_enhanced_processor(
            queue=[],
            priority_map=priority_map,
            default_priority=1,
            max_depth=3,
        )
        for key in result:
            assert result[key] == []

    @pytest.mark.asyncio
    async def test_default_priority_usage(
