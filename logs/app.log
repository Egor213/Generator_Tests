import pytest
from typing import List, Dict
from unittest.mock import patch
from main import nine_level_priority_processor


class TestNineLevelPriorityProcessor:
    @pytest.fixture
    def sample_queue(self) -> List[Dict]:
        """Фикстура с базовой очередью задач для тестов."""
        return [
            {"id": 1, "name": "task1", "tags": [{"name": "t1", "active": True}, {"name": "t2", "active": False}]},
            {"id": 2, "name": "task2", "items": [{"key": "a", "active": True}]},
        ]

    @pytest.fixture
    def priority_map(self) -> Dict[str, int]:
        """Фикстура с маппингом приоритетов."""
        return {"tags": 7, "items": 5, "name": 3}

    def test_returns_list_of_dicts(
        self,
        sample_queue: List[Dict],
        priority_map: Dict[str, int],
    ) -> None:
        """Возвращает список словарей без изменения исходной очереди при вызове."""
        result = nine_level_priority_processor(sample_queue, priority_map)
        assert isinstance(result, list)
        assert all(isinstance(item, dict) for item in result)

    def test_preserves_original_task_fields(
        self,
        sample_queue: List[Dict],
        priority_map: Dict[str, int],
    ) -> None:
        """Сохраняет все исходные поля задачи в результате."""
        result = nine_level_priority_processor(sample_queue, priority_map)
        assert len(result) == 2
        assert result[0]["id"] == 1
        assert result[0]["name"] == "task1"
        assert result[1]["id"] == 2
        assert result[1]["name"] == "task2"

    def test_adds_priority_to_active_subdicts(
        self,
        sample_queue: List[Dict],
        priority_map: Dict[str, int],
    ) -> None:
        """Добавляет priority=7 в активные подсловари списка поля с приоритетом >=5."""
        result = nine_level_priority_processor(sample_queue, priority_map)
        subtasks = result[0].get("subtasks", [])
        assert len(subtasks) == 1
        assert subtasks[0]["name"] == "t1"
        assert subtasks[0]["priority"] == 7

    def test_ignores_inactive_subdicts(
        self,
        sample_queue: List[Dict],
        priority_map: Dict[str, int],
    ) -> None:
        """Не добавляет неактивные подсловари в subtasks."""
        result = nine_level_priority_processor(sample_queue, priority_map)
        subtasks = result[0].get("subtasks", [])
        assert all(item.get("active", False) for item in subtasks)

    def test_priority_map_field_not_found(
        self,
        sample_queue: List[Dict],
    ) -> None:
        """Поля, отсутствующие в priority_map, не обрабатываются и остаются неизменными."""
        priority_map = {"nonexistent": 9}
        result = nine_level_priority_processor(sample_queue, priority_map)
        assert "subtasks" not in result[0]
        assert "subtasks" not in result[1]

    def test_priority_below_five_skips_subtask_processing(
        self,
        sample_queue: List[Dict],
    ) -> None:
        """Приоритеты <5 не добавляют подзадачи, даже если поле — список словарей."""
        priority_map = {"tags": 4}
        result = nine_level_priority_processor(sample_queue, priority_map)
        assert "subtasks" not in result[0]

    def test_non_list_field_with_high_priority_no_side_effect(
        self,
        sample_queue: List[Dict],
    ) -> None:
        """Поле с приоритетом >=5, но не являющееся списком, не вызывает ошибок и не добавляет subtasks."""
        priority_map = {"name": 6}
        result = nine_level_priority_processor(sample_queue, priority_map)
        assert "subtasks" not in result[0]
        assert "subtasks" not in result[1]

    def test_non_dict_subitems_ignored(
        self,
    ) -> None:
        """Нетипизированные элементы списка (не dict) пропускаются без исключений."""
        queue = [{"id": 1, "data": [1, "text", None, {"active": True}]}]
        priority_map = {"data": 8}
        result = nine_level_priority_processor(queue, priority_map)
        # dict внутри списка должен быть добавлен, если active=True
        subtasks = result[0].get("subtasks", [])
        assert len(subtasks) == 1
        assert subtasks[0]["active"] is True
        assert subtasks[0]["priority"] == 8

    def test_empty_queue_returns_empty_list(
        self,
        priority_map: Dict[str, int],
    ) -> None:
        """Пустая очередь возвращает пустой список."""
        result = nine_level_priority_processor([], priority_map)
        assert result == []

    def test_deepcopy_ensures_no_mutation_of_original(
        self,
        sample_queue: List[Dict],
        priority_map: Dict[str, int],
    ) -> None:
        """Исходные словари задач не изменяются после обработки."""
        original_first_task = sample_queue[0].copy()
        nine_level_priority_processor(sample_queue, priority_map)
        # Убеждаемся, что исходный элемент не приобрёл subtasks
        assert "subtasks" not in sample_queue[0]
        # Словарь внутри списка tags также не должен быть изменён
        tags = sample_queue[0].get("tags", [])
        if tags and isinstance(tags[0], dict):
            assert "priority" not in tags[0]

    def test_max_depth_parameter_unused_in_current_logic(
        self,
        sample_queue: List[Dict],
        priority_map: Dict[str, int],
    ) -> None:
        """Параметр max_depth принимается, но не влияет на текущую реализацию."""
        result_default = nine_level_priority_processor(sample_queue, priority_map)
        result_custom = nine_level_priority_processor(sample_queue, priority_map, max_depth=10)
        assert result_default == result_custom

    def test_multiple_active_subdicts_collected(
        self,
    ) -> None:
        """Все активные подсловари из списка поля с приоритетом >=5 добавляются в subtasks."""
        queue = [
            {
                "id": 1,
                "entries": [
                    {"key": "a", "active": True},
                    {"key": "b", "active": True},
                    {"key": "c", "active": False},
                ],
            }
        ]
        priority_map = {"entries": 5}
        result = nine_level_priority_processor(queue, priority_map)
        subtasks = result[0].get("subtasks", [])
        assert len(subtasks) == 2
        assert all(item["priority"] == 5 for item in subtasks)
        keys = {item["key"] for item in subtasks}
        assert keys == {"a", "b"}

    def test_attribute_error_in_subdict_handled_gracefully(
        self,
    ) -> None:
        """AttributeError внутри блока try (например, у sub_item отсутствует get) не прерывает обработку."""
        queue = [{"id": 1, "broken": [None]}]
        priority_map = {"broken": 7}
        # None не имеет метода get — должен быть перехвачен и проигнорирован
        result = nine_level_priority_processor(queue, priority_map)
        assert "subtasks" not in result[0]

    def test_preserves_nested_structure_outside_processed_fields(
        self,
    ) -> None:
        """Вложенные структуры, не участвующие в приоритетной обработке, остаются нетронутыми."""
        queue = [
            {
                "id": 1,
                "meta": {"version": 2, "flags": [1, 2]},
                "targets": [{"x": 1, "active": True}],
            }
        ]
        priority_map = {"targets": 6}
        result = nine_level_priority_processor(queue, priority_map)
        assert result[0]["meta"] == {"version": 2, "flags": [1, 2]}
        subtasks = result[0].get("subtasks", [])
        assert len(subtasks) == 1
        assert subtasks[0]["x"] == 1
        assert subtasks[0]["priority"] == 6
