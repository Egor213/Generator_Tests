        keys: List[str],
        min_depth: int,
        max_depth: int,
        expected: List[Any],
    ) -> None:
        """Проверяет различные варианты входных данных и параметров глубины."""
        result = seven_level_maze(data, keys, min_depth, max_depth)
        assert result == expected

