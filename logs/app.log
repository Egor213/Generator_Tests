import pytest
from typing import List, Dict, Any
from main import seven_level_maze


class TestSevenLevelMazeUncovered:
    """Тесты для покрытия непокрытых ветвей функции seven_level_maze."""

    @pytest.mark.asyncio
    async def test_seven_level_maze_depth_exceeds_max_continue(self) -> None:
        """Проверяет, что при depth > max_depth выполняется continue (пропуск объекта)."""
        data = [{"a": {"b": "target"}}]
        keys = ["a", "b"]
        # Устанавливаем max_depth=0, чтобы при первом же погружении depth=1 > max_depth
        # и сработал continue для вложенного dict
        result = seven_level_maze(data, keys, min_depth=0, max_depth=0)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_dict_items_iteration(self) -> None:
        """Проверяет итерацию по obj.items() для dict (покрывает цикл по ключам)."""
        data = [{"x": 1, "y": 2}]
        keys = ["x"]
        # key_pos=0, k=="x" совпадает с keys[0], но v не dict/list, поэтому дальше не пойдёт.
        # Цель — покрыть сам цикл for k, v in obj.items().
        result = seven_level_maze(data, keys, min_depth=0, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_key_pos_less_len_keys_and_key_match(self) -> None:
        """Проверяет условие key_pos < len(keys) and k == keys[key_pos]."""
        data = [{"a": {"b": "value"}}]
        keys = ["a", "b"]
        # При key_pos=0, k="a" совпадает с keys[0], затем погружаемся.
        # При key_pos=1, k="b" совпадает с keys[1], и depth>=min_depth, v — str (не dict/list),
        # поэтому вложенные условия не проходят, но ветка условия уже выполняется.
        result = seven_level_maze(data, keys, min_depth=0, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_depth_gte_min_depth(self) -> None:
        """Проверяет условие depth >= min_depth внутри совпадения ключа."""
        data = [{"a": {"b": "value"}}]
        keys = ["a", "b"]
        # min_depth=1, depth при "b" = 1 => условие выполняется.
        result = seven_level_maze(data, keys, min_depth=1, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_value_is_dict_or_list(self) -> None:
        """Проверяет isinstance(v, (dict, list)) при совпадении ключа и depth >= min_depth."""
        data = [{"a": {"b": {"c": "found"}}}]
        keys = ["a", "b", "c"]
        # При key_pos=1 (b), v = {"c": "found"} — dict, условие проходит.
        # Затем key_pos+1 == len(keys) ещё не выполняется, поэтому пойдёт в stack.append.
        result = seven_level_maze(data, keys, min_depth=0, max_depth=5)
        assert result == []

    @pytest.mark.asyncio
    async def test_seven_level_maze_key_pos_plus_one_equals_len_keys_append_result(self) -> None:
        """Проверяет, что при key_pos + 1 == len(keys) значение добавляется в results."""
        data = [{"a": {"b": "final"}}]
        keys = ["a", "b"]
        # При key_pos=1 (b), key_pos+1 == len(keys) => results.append(v).
        result = seven_level_maze(data, keys, min_depth=0, max_depth=5)
        assert result == ["final"]

    @pytest.mark.asyncio
    async def test_seven_level_maze_key_pos_plus_one_not_equals_len_keys_stack_append(self) -> None:
        """Проверяет, что при key_pos+1 != len(keys) объект добавляется в stack для дальнейшего поиска."""
        data = [{"a": {"b": {"c": "deep_value"}}}]
        keys = ["a", "b", "c"]
        # При key_pos=1 (b), v = {"c": "deep_value"} — dict, key_pos+1=2 != len(keys)=3,
        # поэтому выполнится stack.append((v, depth+1, key_pos+1)).
        result = seven_level_maze(data, keys, min_depth=0, max_depth=5)
        assert result == ["deep_value"]
