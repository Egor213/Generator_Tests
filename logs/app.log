        "data,keys,min_depth,max_depth,expected",
        [
            (
                [{"a": {"b": {"c": [1, 2]}}}],
                ["a", "b", "c"],
                1,
                5,
                [[1, 2]],
            ),
            (
                [{"x": {"y": {"z": {"w": 999}}}}],
                ["x", "y", "z", "w"],
                2,
                5,
                [],
            ),
            (
                [
                    {"k": {"k": {"k": "deep"}}},
                    {"k": "shallow"},
                ],
                ["k", "k", "k"],
                1,
                5,
                ["deep"],
            ),
            (
